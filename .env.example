VITE_API_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Cloudflare Turnstile — public site key (paired with TURNSTILE_SECRET_KEY in backend/.env)
VITE_TURNSTILE_SITE_KEY=

# PostHog analytics — get from https://posthog.com project settings
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# PostHog server-side (used by scripts/create-posthog-funnels.mjs — NOT exposed to browser)
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
