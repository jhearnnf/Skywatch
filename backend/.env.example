PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/skywatch?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Resend — transactional email (https://resend.com)
# Used to send welcome emails on registration
RESEND_API_KEY=your_resend_api_key_here
