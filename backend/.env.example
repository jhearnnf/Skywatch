PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/skywatch?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# OpenRouter — used server-side for AI features (never exposed to the browser)
OPENROUTER_KEY=your_openrouter_api_key_here
# Optional: separate key for APTITUDE_SYNC game; falls back to OPENROUTER_KEY if not set
OPENROUTER_KEY_APTITUDE=your_openrouter_aptitude_key_here
# Optional: separate key used exclusively by the admin Socials draft feature
# (X/Twitter post drafting). Falls back to OPENROUTER_KEY if not set.
OPENROUTER_KEY_SOCIALS=your_openrouter_socials_key_here

# Resend — transactional email (https://resend.com)
# Used to send welcome emails on registration
RESEND_API_KEY=your_resend_api_key_here

# Cloudinary — cloud image storage for brief images (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe — subscription payments (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SILVER_PRICE_ID=price_...
STRIPE_GOLD_PRICE_ID=price_...

# Cloudflare Turnstile — bot-prevention CAPTCHA for signup (https://dash.cloudflare.com/?to=/:account/turnstile)
# Leave blank to disable server-side verification (the admin UI will show a warning if the flag is on).
TURNSTILE_SECRET_KEY=

# X (Twitter) API — OAuth 2.0 PKCE for posting from the admin Socials panel
# Create app at https://developer.x.com — set the callback URL to X_REDIRECT_URI below.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:5000/api/admin/social/x/callback

# AES-256-GCM key for encrypting OAuth tokens at rest. Generate with:
#   openssl rand -base64 32
SOCIAL_TOKEN_KEY=

# GitHub API — used for "brand transparency" social posts that surface recent
# significant commits. Use a fine-grained PAT scoped only to this repo with
# Contents:read permission. Leave both blank to disable brand-transparency posts.
GITHUB_REPO=jhearnnf/Skywatch
GITHUB_TOKEN=
